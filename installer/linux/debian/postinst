#!/bin/bash
set -e

CONFIG_DIR="/etc/lark-agent-bridge"

# 创建配置目录
mkdir -p "$CONFIG_DIR"

# 如果配置文件不存在，复制模板
if [ ! -f "$CONFIG_DIR/config.yaml" ]; then
    if [ -f "/usr/share/lark-agent-bridge/config.example.yaml" ]; then
        cp "/usr/share/lark-agent-bridge/config.example.yaml" "$CONFIG_DIR/config.yaml"
    fi
    echo ""
    echo "=== lark-agent-bridge 已安装 ==="
    echo ""
    echo "首次使用请运行配置向导："
    echo "  lark-agent-bridge config init"
    echo ""
    echo "然后安装并启动服务："
    echo "  sudo lark-agent-bridge install"
    echo "  sudo lark-agent-bridge start"
    echo ""
fi

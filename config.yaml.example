# lark-agent-bridge 配置文件

agent:
  # AI Agent 类型: codex | claude
  type: codex
  # Codex CLI 命令路径
  codex_cmd: codex
  # Claude Code 命令路径
  claude_cmd: claude

feishu:
  # 监听的事件类型
  event_types:
    - im.message.receive_v1
  # 处理中表情（飞书表情类型）
  working_emoji: OnIt
  # 错误表情
  error_emoji: Frown

stream:
  # 流式更新间隔（秒）
  interval: 3
  # 飞书单条消息字符上限，超出自动分片
  message_limit: 4000

session:
  # 会话超时（秒），0 = 永不超时
  timeout: 0

workspace:
  # 默认工作目录
  dir: "."

log:
  # 日志文件路径
  file: ./logs/bridge.log

retry:
  # 飞书 API 最大重试次数
  max_retries: 3

# AI Agent to use: codex | claude
AGENT_TYPE=codex

# Codex CLI command (default: codex)
CODEX_CMD=codex

# Claude Code command (default: claude)
CLAUDE_CMD=claude

# Feishu bot chat ID to reply to (optional, auto-detected from event if empty)
CHAT_ID=

# Working emoji (shown while agent is processing)
# See: https://open.feishu.cn/document/uAjLw4CM/ukTMukTMukTM/reference/im-v1/message-reaction/emojis-introduce
WORKING_EMOJI=OnIt

# Log file path
LOG_FILE=./logs/bridge.log
